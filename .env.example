# .env.example
# Template configuration for the MultiAgentEval Harness.
# Rename this file to .env and fill in your credentials.

# --- Agent Connectivity ---
# The URL where the engine can reach your agent adapter.
# For Docker Compose, the default service name is 'agent'.
AGENT_API_URL=http://localhost:5001/execute_task

# --- Evaluation Parameters ---
# Number of turns in a single conversation before capping.
EVAL_MAX_TURNS=5
# Default industry tag if none is provided in the scenario.
DEFAULT_INDUSTRY=telecom

# --- LLM Judge Layer ---
# Supported providers: ollama, openai, anthropic, gemini, grok
JUDGE_PROVIDER=ollama
JUDGE_MODEL=llama3

# --- Provider Hosts ---
OLLAMA_HOST=http://localhost:11434
AUTOGEN_API_URL=http://localhost:5002/execute_task

# --- Dashboard & Console Security ---
# Dashboard API Key for sensitive execution (REST API / Console).
# MANDATORY for production. Use python -c "import secrets; print(secrets.token_hex(32))"
# DASHBOARD_API_KEY=

# --- Cryptographic Identity ---
# Private Key for ED25519 Artifact Signing and Verification Certificates.
# If left empty, the engine will auto-generate a persistent key in .aes/keys/
# AES_PRIVATE_KEY=

# --- Propagation & Throttling ---
# Seconds to wait between agent turns (useful for rate-limited APIs).
# EVAL_TURN_THROTTLE=0.0
# Number of traces to maintain in runs.jsonl before it gets rotated.
# Individual trace files (e.g. runs/uuid.jsonl) are NEVER rotated.
RUN_LOG_MASTER_LIMIT=300

# --- API Keys (Uncomment and fill to use proprietary models) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# XAI_API_KEY=

# --- Feature Flags ---
# Enable the built-in demo traces in the console.
ENABLE_DEMO=false
# Comma-separated list of globally enabled tool shims (* for all).
GLOBAL_ENABLED_SHIMS=git,api,database,slack,crm,email,calendar,jira,cloud,terminal,stripe,erp,browser,kb,support,social,vector,cicd,iot,security
# Enable the diagnostics debug toggle button in the console.
DEBUG=false
