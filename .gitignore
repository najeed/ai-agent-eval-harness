# .gitignore

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.pypirc

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
.mypy_cache/

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# IDEs
.idea/
.vscode/

# --- Local Development Scripts and Sources ---

# Ignore the scenario parsing script
parse_scenarios.py

# Ignore the folder containing raw scenario source files
scenario_sources/

# Ignore the folder containing industry analysis
industries_assessment/

# Ignore the social media icons and branding assets
social_media_icon.png
social_media_icon2.png
AI Agent Eval Harness.png

# Ignore stale generated docs
enhanced_README.md
DOCUMENTATION_SUMMARY.md

# Ignore empty log directory
logs/

# Local developer TODO tracker
.todo.md

# Sphinx build artifacts
docs/_build/
docs/build/

# --- Execution Artifacts ---
runs/
results/
reports/
tmp/

# --- Dependencies ---
node_modules/
.npm/
.yarn/

# --- System Files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Logs ---
*.log
