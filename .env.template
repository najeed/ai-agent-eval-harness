# AES Evaluation Harness - Environment Configuration Template
# Instructions: Copy this file to '.env' and fill in your credentials.

# --- Project Authentication ---
# ED25519 Private Key for result signing (Required for Phase 4 walkthroughs)
AES_PRIVATE_KEY=your_signing_key_here

# Dashboard Authentication (Phase 4 Security)
DASHBOARD_API_KEY=your_dashboard_secret_here

# --- Provider Agnostic Credentials ---
# The harness supports multiple backends. Set the keys for your desired providers.
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
GOOGLE_API_KEY=your_gemini_key_here
XAI_API_KEY=your_grok_key_here

# --- Default Judge Controls ---
# Set the default evaluator for the harness
JUDGE_PROVIDER=openai
JUDGE_MODEL=gpt-4

# --- Industrial Scaling & Throttling ---
# Prevents resource exhaustion during large-scale batches
EVAL_TURN_THROTTLE=0.0
EVAL_MAX_TURNS=10
CONCURRENCY_LIMIT=10

# --- Authoritative Paths (Optional) ---
# PROJECT_ROOT=path/to/your/project
# RUN_LOG_DIR=path/to/logs
# REPORTS_DIR=path/to/reports
