{
  "name": "ai-agent-eval-harness",
  "displayName": "AgentV",
  "description": "VS Code extension for the AgentV",
  "version": "0.1.0",
  "publisher": "AgentV",
  "dependencies": {
    "flatted": "^3.4.2"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agentv.runScenario",
        "title": "Eval: Run Scenario"
      },
      {
        "command": "agentv.openConsole",
        "title": "Eval: Open Visual Debugger"
      }
    ],
    "keybindings": [
      {
        "command": "agentv.openConsole",
        "key": "f5",
        "when": "editorTextFocus"
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": [
          "scenarios/*.json",
          "industries/**/*.json",
          "enterprise/packs/*.json"
        ],
        "url": "./aes.schema.json"
      }
    ]
  },
  "scripts": {
    "sync-schema": "node ./scripts/sync-aes.js",
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "node ./test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "eslint": "^8.41.0"
  }
}