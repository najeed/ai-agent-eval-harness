{
  "name": "ai-agent-eval-harness",
  "displayName": "MultiAgentEval",
  "description": "VS Code extension for the MultiAgentEval",
  "version": "0.1.0",
  "publisher": "opencore",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "multiagent-eval.runScenario",
        "title": "Eval: Run Scenario"
      },
      {
        "command": "multiagent-eval.openConsole",
        "title": "Eval: Open Admin Console"
      }
    ],
    "keybindings": [
      {
        "command": "multiagent-eval.openConsole",
        "key": "f5",
        "when": "editorTextFocus"
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": [
          "scenarios/*.json",
          "industries/**/*.json",
          "enterprise/packs/*.json"
        ],
        "url": "./aes.schema.json"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "node ./test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "eslint": "^8.41.0"
  }
}
