{
  "forensics": {
    "extensions": [
      ".jsonl",
      ".log",
      ".json",
      ".png",
      ".jpg",
      ".pdf",
      ".csv",
      ".db",
      ".sqlite",
      ".txt",
      ".parquet",
      ".yaml",
      ".yml",
      ".sql",
      ".patch",
      ".diff",
      ".zip",
      ".tar.gz",
      ".tgz",
      ".html",
      ".svg"
    ],
    "mandatory_patterns": [
      "audit_.*\\.json",
      "forensics/.*\\.json",
      "forensics/.*\\.jsonl",
      "forensics/.*\\.csv"
    ],
    "exclusion_patterns": [
      ".*\\.node$",
      ".*\\.cache$",
      ".*\\.pyc$",
      ".*\\.pyo$",
      ".*\\.pyd$",
      ".*\\.exe$",
      ".*\\.dll$",
      ".*\\.tmp$",
      ".*\\.cpuprofile$",
      "thumbs\\.db",
      "desktop\\.ini",
      "\\.DS_Store",
      "AdobeARM\\.log",
      "MpCmdRun\\.log",
      "pipecom\\.log",
      "StructuredQuery\\.log"
    ],
    "max_artifact_size": 5242880
  }
}