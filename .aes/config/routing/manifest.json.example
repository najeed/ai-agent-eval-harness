{
  "$schema": "../../../spec/routing/routing.schema.json",
  "mappings": {
    "telecom_agent": {
      "protocol": "http",
      "endpoint": "http://localhost:5001/execute_task",
      "metadata": {
        "provider": "docker",
        "region": "us-east-1"
      }
    },
    "default": {
      "protocol": "local",
      "endpoint": "eval_runner.adapters.native.SubprocessAdapter"
    }
  }
}
