{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Eval Specification (AES) v1.4.0",
  "type": "object",
  "required": ["aes_version", "metadata", "workflow"],
  "properties": {
    "aes_version": {
      "type": "number",
      "const": 1.4
    },
    "metadata": {
      "$ref": "definitions/metadata.json"
    },
    "workflow": {
      "$ref": "definitions/workflow.json"
    },
    "evaluation": {
      "$ref": "definitions/evaluation.json"
    },
    "environmental_snapshot": {
      "type": "object",
      "description": "A resolved snapshot of the environmental provisioning registry (shim_resources.json) captured at run start."
    }
  }
}