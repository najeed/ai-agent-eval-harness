{
  "aes_version": 1.2,
  "metadata": {
    "name": "Transcribe Audio Meeting",
    "compliance_level": "Standard"
  },
  "description": "An agent must transcribe an audio file of a client workshop.",
  "industry": "Consulting",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Process the provided audio file.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent successfully ingests the audio file."
        }
      },
      {
        "id": "task-2",
        "task_description": "Transcribe the audio to text.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent produces a text transcript of the meeting."
        }
      },
      {
        "id": "task-3",
        "task_description": "Optionally, identify different speakers in the transcript.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent labels the text with 'Speaker 1', 'Speaker 2', etc."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}