{
  "aes_version": 1.2,
  "metadata": {
    "name": "Translate Report for International Client",
    "compliance_level": "Standard"
  },
  "description": "An agent must translate a final report from English to Spanish for a client's international office.",
  "industry": "Consulting",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Ingest the final English report.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent successfully loads the document."
        }
      },
      {
        "id": "task-2",
        "task_description": "Translate the entire document text to Spanish.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent produces a translated version of the text."
        }
      },
      {
        "id": "task-3",
        "task_description": "Format the translated text into a new document, preserving the original structure and headings.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent creates a new, well-formatted document in Spanish."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}