{
  "aes_version": 1.4,
  "metadata": {
    "name": "Develop a Sustainability (ESG) Strategy",
    "compliance_level": "Standard",
    "id": "00179-sustainability-esg-strategy"
  },
  "description": "An agent must draft a basic ESG (Environmental, Social, Governance) strategy for a client.",
  "industry": "Consulting",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Brainstorm initiatives for the 'Environmental' pillar (e.g., 'reduce carbon footprint', 'implement recycling program').",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent generates relevant environmental initiatives.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Brainstorm initiatives for the 'Social' pillar (e.g., 'improve employee diversity', 'community volunteering program').",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent generates relevant social initiatives.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Brainstorm initiatives for the 'Governance' pillar (e.g., 'increase board transparency', 'implement ethics training').",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent generates relevant governance initiatives.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-4",
        "task_description": "Compile the brainstormed ideas into a structured ESG strategy document.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent creates a report outlining the proposed ESG strategy.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      },
      {
        "from": "task-3",
        "to": "task-4"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}