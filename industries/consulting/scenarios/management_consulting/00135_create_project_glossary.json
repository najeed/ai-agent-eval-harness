{
  "aes_version": 1.4,
  "metadata": {
    "name": "Create a Project Glossary",
    "compliance_level": "Standard",
    "id": "00135-create-project-glossary"
  },
  "description": "An agent must scan a collection of project documents and create a glossary of key terms and acronyms.",
  "industry": "Consulting",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Process all documents in a specified project folder.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent successfully reads all documents.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Identify all acronyms and technical terms used in the documents.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent extracts a list of potential glossary terms.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "For each term, find its definition or first usage context within the documents.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent provides a definition or context for each term.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-4",
        "task_description": "Format the findings into a two-column glossary table (Term | Definition).",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent generates a well-structured glossary.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      },
      {
        "from": "task-3",
        "to": "task-4"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}