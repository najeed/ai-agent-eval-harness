{
  "aes_version": 1.4,
  "metadata": {
    "name": "Find Location of a City-Owned Asset",
    "compliance_level": "Standard",
    "id": "13537-find-location-of-a-city-owned-asset"
  },
  "description": "A public works employee needs to find the exact location of a specific piece of equipment (e.g., a mobile generator) for deployment.",
  "industry": "Smart Cities",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Receive a request for the location of 'Generator #12'.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent acknowledges the location request.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Query the asset management system for the specified asset ID.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent retrieves the asset's details.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Retrieve the asset's last reported GPS location from its attached IoT tracker.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "The system displays the generator's current location on a map.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}