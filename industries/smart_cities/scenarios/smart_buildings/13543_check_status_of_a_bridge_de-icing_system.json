{
  "aes_version": 1.4,
  "metadata": {
    "name": "Check Status of a Bridge De-icing System",
    "compliance_level": "Standard",
    "id": "13543-check-status-of-a-bridge-de-icing-system"
  },
  "description": "With freezing temperatures forecasted, an operator must ensure the heating elements on a critical bridge are operational.",
  "industry": "Smart Cities",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Receive a 'Freezing Temperatures Expected' weather alert.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent acknowledges the weather forecast.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Run a remote diagnostic on the 'Central Bridge' de-icing system.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent initiates the system test.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Review the diagnostic report, which confirms all heating elements are functional and ready.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent verifies the system is ready for the cold weather.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
