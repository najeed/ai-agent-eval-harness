{
  "aes_version": 1.2,
  "metadata": {
    "name": "Backup - Configure New Backup Job",
    "compliance_level": "Standard"
  },
  "description": "A new server has been deployed, and it needs to be added to the nightly backup schedule.",
  "industry": "Information Technology Service",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Install the backup agent software on the new server.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "The agent is successfully installed."
        }
      },
      {
        "id": "task-2",
        "task_description": "In the backup console, create a new backup job for the new server.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "A new job is created."
        }
      },
      {
        "id": "task-3",
        "task_description": "Configure the job with the correct schedule, retention policy, and encryption settings, then run the first backup.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "The server is now being backed up according to the client's policy."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}