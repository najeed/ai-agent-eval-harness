{
  "aes_version": 1.2,
  "metadata": {
    "name": "User Account - Unlock Account",
    "compliance_level": "Standard"
  },
  "description": "A user reports their Active Directory account is locked out after too many failed password attempts.",
  "industry": "Information Technology Service",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Verify the user's identity.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "The user is authenticated."
        }
      },
      {
        "id": "task-2",
        "task_description": "Check the account status in Active Directory and confirm it is locked.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "The technician verifies the account's locked status."
        }
      },
      {
        "id": "task-3",
        "task_description": "Unlock the user's account.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "The account is successfully unlocked, and the user can now attempt to log in again."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}