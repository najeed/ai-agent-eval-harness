{
  "aes_version": 1.2,
  "metadata": {
    "name": "Client Onboarding - Setup in PSA",
    "compliance_level": "Standard"
  },
  "description": "A new client needs to be set up in the Professional Services Automation (PSA) tool.",
  "industry": "Information Technology Service",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Create a new company record for the client in the PSA.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "The client company is created."
        }
      },
      {
        "id": "task-2",
        "task_description": "Add all of the client's users as contacts under the company record.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "All client contacts are created."
        }
      },
      {
        "id": "task-3",
        "task_description": "Create the recurring service contract in the PSA, specifying the services provided and the monthly fee.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "The client's contract is set up correctly for future billing and SLA tracking."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}