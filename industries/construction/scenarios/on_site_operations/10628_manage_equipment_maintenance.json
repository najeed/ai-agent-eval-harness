{
  "aes_version": 1.4,
  "metadata": {
    "name": "Schedule Routine Equipment Maintenance",
    "compliance_level": "Standard",
    "id": "10628-manage-equipment-maintenance"
  },
  "description": "A notification indicates that a backhoe is due for its 250-hour service. The site manager must schedule this maintenance.",
  "industry": "Construction",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Acknowledge the maintenance alert for 'Backhoe #1'.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent confirms receipt of the maintenance alert.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Schedule a service appointment with the equipment dealer for the end of the week.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Maintenance is successfully scheduled.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Block out 'Backhoe #1' as unavailable in the resource schedule for the day of the service.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "The equipment schedule is updated to prevent booking conflicts.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}