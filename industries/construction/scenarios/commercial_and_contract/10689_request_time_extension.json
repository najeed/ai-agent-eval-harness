{
  "aes_version": 1.2,
  "metadata": {
    "name": "Request a Time Extension",
    "compliance_level": "Standard"
  },
  "description": "Due to a client-caused delay, a PM needs to submit a formal request for a contract time extension.",
  "industry": "Construction",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Document the client-caused delay, including its start date, end date, and impact on the critical path.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "The delay is fully documented."
        }
      },
      {
        "id": "task-2",
        "task_description": "Draft a formal contract modification request for a time extension, citing the relevant contract clauses.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "A formal request is drafted."
        }
      },
      {
        "id": "task-3",
        "task_description": "Submit the request to the client for their approval.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "The time extension request is sent to the client."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}