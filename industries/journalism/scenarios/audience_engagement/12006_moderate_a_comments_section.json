{
  "aes_version": 1.4,
  "metadata": {
    "name": "Moderate a Comments Section",
    "compliance_level": "Standard",
    "id": "12006-moderate-a-comments-section"
  },
  "description": "A community manager must moderate the comments section on a controversial article, removing hate speech while allowing for civil debate.",
  "industry": "Journalism",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Scan the comments section for any posts that violate the community guidelines (e.g., personal attacks, spam, hate speech).",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent identifies comments that need to be removed.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Delete the violating comments.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "The inappropriate comments are removed from the page.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "If a user is a repeat offender, ban them from commenting.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "The problematic user is banned.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}