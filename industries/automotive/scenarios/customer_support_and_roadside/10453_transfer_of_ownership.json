{
  "aes_version": 1.4,
  "metadata": {
    "name": "Process Transfer of Ownership",
    "compliance_level": "Standard",
    "id": "10453-transfer-of-ownership"
  },
  "description": "A customer sold their vehicle to a private party and wants to transfer the remaining connected services and warranty to the new owner.",
  "industry": "Automotive",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Verify the identity of the original owner.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent authenticates the seller.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Collect the new owner's name and contact information.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent gathers the buyer's details.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Update the vehicle's record in the system with the new owner's information, initiating the transfer process for any applicable services.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent successfully updates the ownership record in the master vehicle database.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
