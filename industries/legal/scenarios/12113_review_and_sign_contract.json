{
  "aes_version": 1.2,
  "metadata": {
    "name": "Execute a Contract via E-signature",
    "compliance_level": "Standard"
  },
  "description": "After negotiations are complete, an attorney needs to send a final version of a contract to both parties for electronic signature.",
  "industry": "Legal",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Upload the final contract document to an e-signature platform like DocuSign.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent successfully uploads the document."
        }
      },
      {
        "id": "task-2",
        "task_description": "Place signature and date blocks for all required signatories.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent correctly tags the document for signature."
        }
      },
      {
        "id": "task-3",
        "task_description": "Send the document to all parties for signature.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "The signing process is initiated."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}