{
  "aes_version": 1.4,
  "metadata": {
    "name": "Document a Client Interaction",
    "compliance_level": "Standard",
    "id": "13080-document-client-interaction"
  },
  "description": "A social worker needs to log a phone call with a client in the case management system.",
  "industry": "Public Sector",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Identify the client's case file.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "The worker locates the correct file.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Select the 'Log Interaction' activity.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "The worker initiates the correct process in the system.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Enter the details of the phone call, including the topics discussed and any follow-up actions, and save the note.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "The worker successfully documents the interaction in the case file.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}