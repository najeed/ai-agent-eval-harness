{
  "aes_version": 1.2,
  "metadata": {
    "name": "Pay Property Taxes Online",
    "compliance_level": "Standard"
  },
  "description": "A homeowner wants to pay their semi-annual property tax bill online.",
  "industry": "Public Sector",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Identify the property using the parcel number or address.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent successfully locates the property and the outstanding tax bill."
        }
      },
      {
        "id": "task-2",
        "task_description": "Securely process the payment via credit card or e-check.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent successfully processes the payment."
        }
      },
      {
        "id": "task-3",
        "task_description": "Provide the homeowner with a receipt and confirmation of payment.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent provides a digital receipt."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
