{
  "aes_version": 1.4,
  "metadata": {
    "name": "Close a Filled Job Requisition",
    "compliance_level": "Standard",
    "id": "11645-close-job-requisition"
  },
  "description": "A candidate has been hired for a role, and the recruiter needs to close the job requisition in the ATS.",
  "industry": "Human Resources",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Identify the job requisition that has been filled.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Recruiter locates the correct requisition.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Update the requisition status to 'Filled/Closed'.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Recruiter successfully updates the status.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Ensure all other candidates for the role have been dispositioned correctly (e.g., rejected).",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Recruiter verifies that no candidates are left in an active state for the closed req.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}