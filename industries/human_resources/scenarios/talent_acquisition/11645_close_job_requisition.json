{
  "aes_version": 1.2,
  "metadata": {
    "name": "Close a Filled Job Requisition",
    "compliance_level": "Standard"
  },
  "description": "A candidate has been hired for a role, and the recruiter needs to close the job requisition in the ATS.",
  "industry": "Human Resources",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Identify the job requisition that has been filled.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Recruiter locates the correct requisition."
        }
      },
      {
        "id": "task-2",
        "task_description": "Update the requisition status to 'Filled/Closed'.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Recruiter successfully updates the status."
        }
      },
      {
        "id": "task-3",
        "task_description": "Ensure all other candidates for the role have been dispositioned correctly (e.g., rejected).",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Recruiter verifies that no candidates are left in an active state for the closed req."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}