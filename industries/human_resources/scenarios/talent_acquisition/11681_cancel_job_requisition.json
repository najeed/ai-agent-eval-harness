{
  "aes_version": 1.2,
  "metadata": {
    "name": "Cancel a Job Requisition",
    "compliance_level": "Standard"
  },
  "description": "Due to a budget change, a hiring manager needs to cancel a job requisition that is currently open.",
  "industry": "Human Resources",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Identify the job requisition to be cancelled.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Recruiter locates the correct requisition in the ATS."
        }
      },
      {
        "id": "task-2",
        "task_description": "Update the requisition status to 'Cancelled'.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Recruiter successfully updates the status."
        }
      },
      {
        "id": "task-3",
        "task_description": "Notify any active candidates that the position is no longer available.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Recruiter sends a notification to all candidates in an active stage for the role."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}