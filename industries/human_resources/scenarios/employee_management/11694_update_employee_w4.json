{
  "aes_version": 1.4,
  "metadata": {
    "name": "Update Employee W-4 Tax Form",
    "compliance_level": "Standard",
    "id": "11694-update-employee-w4"
  },
  "description": "An employee needs to change their tax withholding information on their W-4 form.",
  "industry": "Human Resources",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Identify the employee.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent confirms the employee's identity.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Direct the employee to the payroll self-service portal where they can electronically update their W-4.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent provides clear self-service instructions.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Advise the employee to consult a tax professional for questions about how to fill out the form.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent correctly states that HR cannot give tax advice.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}