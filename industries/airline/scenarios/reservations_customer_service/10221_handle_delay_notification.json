{
  "aes_version": 1.4,
  "metadata": {
    "name": "Handle a Flight Delay Notification",
    "compliance_level": "Standard",
    "id": "10221-handle-delay-notification"
  },
  "description": "The operations team has announced a 2-hour delay for an upcoming flight. A customer service agent must inform the passengers.",
  "industry": "Airline",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Receive the delay information for the specific flight, including the new estimated departure time.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent acknowledges the delay details.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Generate the list of all passengers on the flight and their contact information.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent retrieves the passenger list.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Send an automated SMS and email notification to all passengers informing them of the delay.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent successfully triggers the automated notifications.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
