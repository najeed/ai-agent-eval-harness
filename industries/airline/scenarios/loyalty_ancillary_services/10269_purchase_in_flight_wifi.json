{
  "aes_version": 1.4,
  "metadata": {
    "name": "Purchase In-Flight Wi-Fi",
    "compliance_level": "Standard",
    "id": "10269-purchase-in-flight-wifi"
  },
  "description": "A passenger on board a flight wants to purchase Wi-Fi access.",
  "industry": "Airline",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "The passenger connects to the onboard Wi-Fi network and is directed to a payment portal.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Passenger accesses the portal.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "The portal displays the available Wi-Fi packages and their prices (e.g., 1-hour pass, full-flight pass).",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Passenger sees the options.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "The passenger selects a package, enters their payment information, and their device is granted internet access.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Passenger successfully purchases and connects to the Wi-Fi.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}