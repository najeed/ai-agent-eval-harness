          "value": "Agent successfully takes payment."
        }
      },
      {
        "id": "task-3",
        "task_description": "Update the booking to reflect the additional piece of baggage and check the bag.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent updates the record and accepts the bag."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
