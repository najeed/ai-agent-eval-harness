{
  "aes_version": 1.4,
  "metadata": {
    "name": "Manage a Group Seat Block",
    "compliance_level": "Standard",
    "id": "10261-manage-group-seat-block"
  },
  "description": "A tour group has a booking and wants to be seated together. A reservations agent must block a group of seats for them.",
  "industry": "Airline",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Retrieve the group booking.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent finds the booking.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Find a block of adjacent seats on the seat map that can accommodate the entire group.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent finds a suitable block of seats.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Assign the seats to the passengers in the group booking.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent successfully assigns all passengers to seats in the block.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
