  "metadata": {
    "name": "Conduct a Pre-Flight Safety Briefing",
    "compliance_level": "Standard",
    "id": "10260-conduct-safety-briefing"
  },
  "description": "Before every flight, the cabin crew must conduct a safety briefing for passengers.",
  "industry": "Airline",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Make an announcement to direct passengers' attention to the briefing.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Crew gets the passengers' attention.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Demonstrate the use of safety equipment, including seatbelts, oxygen masks, and life vests.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Crew performs the safety demonstration.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Point out the emergency exits and ensure the exit rows are clear.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Crew completes the briefing and performs a final cabin check.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
