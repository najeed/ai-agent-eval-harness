{
  "aes_version": 1.2,
  "metadata": {
    "name": "Open a Certificate of Deposit (CD)",
    "compliance_level": "Standard"
  },
  "description": "A customer wants to open a 12-month CD with $10,000.",
  "industry": "Finance",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Present the available CD terms and their corresponding interest rates (APY).",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent clearly presents the rate for the 12-month CD."
        }
      },
      {
        "id": "task-2",
        "task_description": "Explain the early withdrawal penalties.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent clearly explains the financial penalty if the customer withdraws the funds before the 12-month term is up."
        }
      },
      {
        "id": "task-3",
        "task_description": "Open the CD account and transfer the funds from the customer's savings account.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent successfully opens the new CD and funds it."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  },
  "initial_state": {
    "session_active": true,
    "user_authenticated": true,
    "system_status": "nominal"
  },
  "policies": {
    "max_spend_limit": 500,
    "requires_approval_for_destructive_actions": true
  }
}