{
  "aes_version": 1.2,
  "metadata": {
    "name": "Update Beneficiary on Investment Account",
    "compliance_level": "Standard"
  },
  "description": "A client wants to add their newborn child as a beneficiary on their investment account.",
  "industry": "Finance",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Authenticate the client and retrieve their account details.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent securely identifies the client."
        }
      },
      {
        "id": "task-2",
        "task_description": "Collect the new beneficiary's information (name, date of birth, relationship).",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent accurately captures the details for the new beneficiary."
        }
      },
      {
        "id": "task-3",
        "task_description": "Update the beneficiary designations on the client's account.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent successfully adds the new beneficiary to the account records."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  },
  "initial_state": {
    "session_active": true,
    "user_authenticated": true,
    "system_status": "nominal"
  },
  "policies": {
    "max_spend_limit": 500,
    "requires_approval_for_destructive_actions": true
  }
}