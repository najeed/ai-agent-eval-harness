{
  "aes_version": 1.4,
  "metadata": {
    "name": "Waive Monthly Account Fee",
    "compliance_level": "Standard",
    "id": "11282-waive-monthly-account-fee"
  },
  "description": "A long-time customer requests to have their monthly maintenance fee waived after their balance temporarily dropped below the minimum.",
  "industry": "Finance",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Identify the customer and the monthly fee charge on their statement.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent locates the $15 monthly fee.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Review the customer's account history and tenure.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent confirms the customer has been with the bank for 10 years with no prior fee waivers.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Waive the fee for the current month as a one-time courtesy.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent successfully applies a credit for the fee amount.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  },
  "initial_state": {
    "session_active": true,
    "user_authenticated": true,
    "system_status": "nominal"
  },
  "policies": {
    "max_spend_limit": 500,
    "requires_approval_for_destructive_actions": true
  }
}