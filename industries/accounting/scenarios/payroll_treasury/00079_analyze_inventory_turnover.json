{
  "aes_version": 1.2,
  "metadata": {
    "name": "Analyze Inventory Turnover",
    "compliance_level": "Standard"
  },
  "description": "A financial analyst wants to calculate the inventory turnover ratio to assess how efficiently the company is managing its inventory.",
  "industry": "Accounting",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Retrieve the total Cost of Goods Sold (COGS) for the year from the income statement.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent gets the annual COGS."
        }
      },
      {
        "id": "task-2",
        "task_description": "Retrieve the beginning and ending inventory balances for the year from the balance sheets.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent gets the inventory values."
        }
      },
      {
        "id": "task-3",
        "task_description": "Calculate the average inventory.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent correctly calculates the average inventory."
        }
      },
      {
        "id": "task-4",
        "task_description": "Calculate the inventory turnover ratio by dividing COGS by the average inventory.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent calculates the final ratio."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      },
      {
        "from": "task-3",
        "to": "task-4"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}