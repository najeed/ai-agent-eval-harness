{
  "aes_version": 1.2,
  "metadata": {
    "name": "Cancel a Rental Car Booking",
    "compliance_level": "Standard"
  },
  "description": "A customer needs to cancel their upcoming car rental reservation.",
  "industry": "Tourism",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Retrieve the car rental booking using the confirmation number.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent locates the correct reservation."
        }
      },
      {
        "id": "task-2",
        "task_description": "Check the cancellation policy.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
