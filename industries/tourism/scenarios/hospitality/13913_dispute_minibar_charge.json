{
  "aes_version": 1.4,
  "metadata": {
    "name": "Dispute a Minibar Charge on Folio",
    "compliance_level": "Standard",
    "id": "13913-dispute-minibar-charge"
  },
  "description": "A guest checking out is disputing a charge for a minibar item they claim they did not consume.",
  "industry": "Tourism",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Retrieve the guest's folio using their name or room number.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent locates the guest's bill.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Identify the specific minibar charge being disputed.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent finds the charge for '$8 - Sparkling Water'.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "As a gesture of goodwill, remove the disputed charge from the guest's folio.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent successfully voids the charge.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}