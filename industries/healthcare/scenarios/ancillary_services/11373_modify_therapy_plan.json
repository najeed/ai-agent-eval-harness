{
  "aes_version": 1.2,
  "metadata": {
    "name": "Modify Therapy Plan of Care",
    "compliance_level": "Standard"
  },
  "description": "A patient is progressing faster than expected in physical therapy. The therapist needs to update their goals in the plan of care.",
  "industry": "Healthcare",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Open the patient's current plan of care.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Therapist locates the active plan of care."
        }
      },
      {
        "id": "task-2",
        "task_description": "Mark several short-term goals as 'Met'.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Therapist updates the status of the existing goals."
        }
      },
      {
        "id": "task-3",
        "task_description": "Add new, more advanced short-term goals and sign the updated plan.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "The plan of care is modified to reflect the patient's current condition and new objectives."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  },
  "initial_state": {
    "session_active": true,
    "user_authenticated": true,
    "system_status": "nominal"
  },
  "policies": {
    "max_spend_limit": 500,
    "requires_approval_for_destructive_actions": true
  }
}