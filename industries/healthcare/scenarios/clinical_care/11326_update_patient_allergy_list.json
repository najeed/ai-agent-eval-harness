{
  "aes_version": 1.2,
  "metadata": {
    "name": "Update Patient Allergy List",
    "compliance_level": "Standard"
  },
  "description": "During an intake, a patient reports a new allergy to penicillin. A nurse needs to update the patient's allergy list.",
  "industry": "Healthcare",
  "workflow": {
    "nodes": [
      {
        "id": "task-0",
        "task_description": "Verify clinician access and patient identity.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Identity verified/authorized"
        }
      },
      {
        "id": "task-1",
        "task_description": "Open the patient's chart and navigate to the allergies section.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Nurse accesses the correct module for managing allergies."
        }
      },
      {
        "id": "task-2",
        "task_description": "Add 'Penicillin' to the allergy list.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Nurse searches for and selects the correct substance."
        }
      },
      {
        "id": "task-3",
        "task_description": "Document the nature of the reaction (e.g., 'Hives') and save the changes.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Nurse adds the specific reaction details, and the new allergy is now prominently displayed in the patient's chart banner."
        }
      }
    ],
    "edges": [
      {
        "from": "task-0",
        "to": "task-1"
      },
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  },
  "initial_state": {
    "session_active": true,
    "user_authenticated": true,
    "system_status": "nominal"
  },
  "policies": {
    "max_spend_limit": 500,
    "requires_approval_for_destructive_actions": true
  }
}