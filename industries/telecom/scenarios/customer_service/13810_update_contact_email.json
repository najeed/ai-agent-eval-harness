{
  "aes_version": 1.2,
  "metadata": {
    "name": "Update Contact Email Address",
    "compliance_level": "Standard"
  },
  "description": "A customer needs to update the primary email address used for notifications and billing.",
  "industry": "Telecom",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Authenticate the customer's identity.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent successfully verifies the customer's identity."
        }
      },
      {
        "id": "task-2",
        "task_description": "Take the new email address from the customer.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent correctly records the new email address."
        }
      },
      {
        "id": "task-3",
        "task_description": "Update the contact email in the customer's profile.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent successfully updates the email address in the CRM."
        }
      },
      {
        "id": "task-4",
        "task_description": "Send a verification email to the new address to complete the process.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent triggers the verification email."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      },
      {
        "from": "task-3",
        "to": "task-4"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  },
  "initial_state": {
    "session_active": true,
    "user_authenticated": true,
    "system_status": "nominal"
  },
  "policies": {
    "max_spend_limit": 500,
    "requires_approval_for_destructive_actions": true
  }
}