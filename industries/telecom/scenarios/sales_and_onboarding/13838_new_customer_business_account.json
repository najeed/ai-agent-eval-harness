{
  "aes_version": 1.2,
  "metadata": {
    "name": "New Customer Acquisition - Business Account",
    "compliance_level": "Standard"
  },
  "description": "A small business owner wants to set up 5 lines with a shared data pool.",
  "industry": "Telecom",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Gather business details and credit check requirements.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent collects all necessary information for a business account setup."
        }
      },
      {
        "id": "task-2",
        "task_description": "Recommend a suitable business plan with a shared data pool.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent recommends the 'Business Flex 100GB' plan."
        }
      },
      {
        "id": "task-3",
        "task_description": "Create the master business account and process the order for the 5 lines.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent successfully creates the account and order."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  },
  "initial_state": {
    "session_active": true,
    "user_authenticated": true,
    "system_status": "nominal"
  },
  "policies": {
    "max_spend_limit": 500,
    "requires_approval_for_destructive_actions": true
  }
}