{
  "aes_version": 1.2,
  "metadata": {
    "name": "Onboarding - SIM-Only Plan Activation",
    "compliance_level": "Standard"
  },
  "description": "A customer has received their new SIM card for a SIM-only plan and needs to activate it.",
  "industry": "Telecom",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Ask the customer for the ICCID number from the new SIM card.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent correctly captures the SIM card number."
        }
      },
      {
        "id": "task-2",
        "task_description": "Activate the SIM card in the billing system.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent successfully activates the SIM."
        }
      },
      {
        "id": "task-3",
        "task_description": "Instruct the customer to insert the SIM and restart their phone.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent provides clear final instructions."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  },
  "initial_state": {
    "session_active": true,
    "user_authenticated": true,
    "system_status": "nominal"
  },
  "policies": {
    "max_spend_limit": 500,
    "requires_approval_for_destructive_actions": true
  }
}