{
  "aes_version": 1.2,
  "metadata": {
    "name": "Cross-sell - Add a Tablet Line",
    "compliance_level": "Standard"
  },
  "description": "A customer with a mobile phone plan wants to add a new line for their tablet.",
  "industry": "Telecom",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Identify the customer and present the available data-only plans for tablets.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent clearly explains the tablet plan options."
        }
      },
      {
        "id": "task-2",
        "task_description": "Explain how the tablet line will be billed alongside their existing phone plan.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent clarifies the billing impact."
        }
      },
      {
        "id": "task-3",
        "task_description": "Process the order to add the tablet line to the customer's account.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent successfully adds the new service line."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
