{
  "aes_version": 1.2,
  "metadata": {
    "name": "New Customer Acquisition - Prepaid Plan",
    "compliance_level": "Standard"
  },
  "description": "A customer wants to sign up for a simple, no-contract prepaid plan.",
  "industry": "Telecom",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Present the available prepaid plans, highlighting data amounts and validity periods.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent clearly explains the prepaid options."
        }
      },
      {
        "id": "task-2",
        "task_description": "Create a new prepaid account for the customer.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent successfully creates the account."
        }
      },
      {
        "id": "task-3",
        "task_description": "Process the initial payment for the selected prepaid plan.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent successfully takes payment and activates the plan."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  },
  "initial_state": {
    "session_active": true,
    "user_authenticated": true,
    "system_status": "nominal"
  },
  "policies": {
    "max_spend_limit": 500,
    "requires_approval_for_destructive_actions": true
  }
}