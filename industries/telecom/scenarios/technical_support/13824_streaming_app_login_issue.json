          "threshold": 1.0
        }
      ],
      "expected_state_changes": [
        {
          "path": "task_completed",
          "value": true
        }
      ]
    },
    {
      "task_id": "task-2",
      "description": "Check the status of the subscription link between the telecom account and the partner service.",
