{
  "aes_version": 1.2,
  "metadata": {
    "name": "Close a Purchase Order",
    "compliance_level": "Standard"
  },
  "description": "A purchase order has been fully received and invoiced, and now needs to be closed in the system.",
  "industry": "Manufacturing",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Find the purchase order.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent retrieves the correct PO."
        }
      },
      {
        "id": "task-2",
        "task_description": "Verify that all line items have been fully received and the corresponding supplier invoice has been paid.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent confirms a '3-way match' between the PO, receipt, and invoice is complete."
        }
      },
      {
        "id": "task-3",
        "task_description": "Change the status of the purchase order to 'Closed'.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent successfully closes the PO."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
