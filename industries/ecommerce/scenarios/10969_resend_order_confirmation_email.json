{
  "aes_version": 1.2,
  "metadata": {
    "name": "Resend Order Confirmation Email",
    "compliance_level": "Standard"
  },
  "description": "A customer claims they never received their order confirmation email and would like it to be resent.",
  "industry": "Ecommerce",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Find the customer's order.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent locates the correct order."
        }
      },
      {
        "id": "task-2",
        "task_description": "Verify the customer's email address on file.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent confirms the email address with the customer."
        }
      },
      {
        "id": "task-3",
        "task_description": "Re-trigger the order confirmation email to be sent to the customer.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent successfully resends the email."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}