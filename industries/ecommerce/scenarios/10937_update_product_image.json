{
  "aes_version": 1.2,
  "metadata": {
    "name": "Update Main Product Image",
    "compliance_level": "Standard"
  },
  "description": "The marketing team has provided a new, higher-quality main image for a best-selling product.",
  "industry": "Ecommerce",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Locate the product by its SKU.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent finds the correct product."
        }
      },
      {
        "id": "task-2",
        "task_description": "Upload the new image.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent successfully uploads the new image file."
        }
      },
      {
        "id": "task-3",
        "task_description": "Set the newly uploaded image as the primary display image for the product.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent updates the product's primary image setting."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
