{
  "aes_version": 1.2,
  "metadata": {
    "name": "Update Customer Shipping Address",
    "compliance_level": "Standard"
  },
  "description": "A customer needs to update their default shipping address in their account.",
  "industry": "Ecommerce",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Identify the customer's account and authenticate their identity.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent verifies the customer's identity."
        }
      },
      {
        "id": "task-2",
        "task_description": "Remove the old shipping address and add the new one provided by the customer.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent successfully updates the address book in the customer's profile."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
