{
  "aes_version": 1.4,
  "metadata": {
    "name": "Cancel an Unshipped Order",
    "compliance_level": "Standard",
    "id": "10918-cancel-unshipped-order"
  },
  "description": "A customer calls to cancel an order they placed an hour ago.",
  "industry": "Ecommerce",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Find the customer's order and check its status.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent finds the order and confirms its status is 'Processing', not 'Shipped'.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Cancel the order in the system.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent successfully cancels the order.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Ensure the payment authorization is voided and the customer will not be charged.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent verifies that the payment transaction has been voided.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}