{
  "aes_version": 1.2,
  "metadata": {
    "name": "Adjust Price to Match Competitor",
    "compliance_level": "Standard"
  },
  "description": "A category manager decides to price-match a key competitor for a specific, popular product.",
  "industry": "Ecommerce",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Identify the product to be price-matched.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent identifies the correct product SKU."
        }
      },
      {
        "id": "task-2",
        "task_description": "Scrape the competitor's website to find their current price for the product.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent retrieves the competitor's price."
        }
      },
      {
        "id": "task-3",
        "task_description": "Update the product's price in the system to match the competitor's price.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent successfully changes the price."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}