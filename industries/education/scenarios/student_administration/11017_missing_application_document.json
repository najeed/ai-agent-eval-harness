{
  "aes_version": 1.4,
  "metadata": {
    "name": "Inquire About Missing Application Document",
    "compliance_level": "Standard",
    "id": "11017-missing-application-document"
  },
  "description": "An applicant received an email that their application is incomplete and wants to know what is missing.",
  "industry": "Education",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Retrieve the applicant's record.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent correctly identifies the applicant.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Check the application checklist in the SIS.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent identifies that the 'Official High School Transcript' is marked as not received.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Inform the applicant which document is missing and explain how to submit it.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent clearly communicates the missing item and submission instructions.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
