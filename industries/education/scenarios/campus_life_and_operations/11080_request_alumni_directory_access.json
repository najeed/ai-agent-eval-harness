{
  "aes_version": 1.4,
  "metadata": {
    "name": "Request Alumni Directory Access",
    "compliance_level": "Standard",
    "id": "11080-request-alumni-directory-access"
  },
  "description": "An alumnus wants to access the online alumni directory to find a former classmate.",
  "industry": "Education",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Identify the alumnus and verify their identity.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent securely identifies the alumnus.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Guide the alumnus to the login page for the alumni portal.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent provides the correct URL.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Explain the privacy policies of the directory and how to use the search function.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent clearly communicates the rules and functionality of the directory.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}