{
  "aes_version": 1.2,
  "metadata": {
    "name": "Request Alumni Directory Access",
    "compliance_level": "Standard"
  },
  "description": "An alumnus wants to access the online alumni directory to find a former classmate.",
  "industry": "Education",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Identify the alumnus and verify their identity.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent securely identifies the alumnus."
        }
      },
      {
        "id": "task-2",
        "task_description": "Guide the alumnus to the login page for the alumni portal.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent provides the correct URL."
        }
      },
      {
        "id": "task-3",
        "task_description": "Explain the privacy policies of the directory and how to use the search function.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent clearly communicates the rules and functionality of the directory."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}