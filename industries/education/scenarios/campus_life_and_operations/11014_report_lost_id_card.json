{
  "aes_version": 1.4,
  "metadata": {
    "name": "Report and Replace Lost Student ID Card",
    "compliance_level": "Standard",
    "id": "11014-report-lost-id-card"
  },
  "description": "A student has lost their ID card and needs to deactivate it and get a replacement.",
  "industry": "Education",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Identify the student and verify their identity.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent securely identifies the student.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Immediately deactivate the lost ID card in the campus security system to prevent misuse.",
        "expected_outcome": [
          {
            "target": "message",
