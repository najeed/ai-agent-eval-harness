{
  "aes_version": 1.4,
  "metadata": {
    "name": "Request Accessible Textbook Format",
    "compliance_level": "Standard",
    "id": "11040-request-accessible-textbook"
  },
  "description": "A student with a visual impairment needs an accessible electronic version (e.g., PDF, EPUB) of a required textbook.",
  "industry": "Education",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Identify the student and verify their accommodation for accessible course materials.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent confirms the student's eligibility.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Collect the textbook information (title, ISBN) and proof of purchase from the student.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent gathers the required documentation.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Request the accessible format from the publisher or an accessibility clearinghouse.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent submits a formal request to the appropriate source for the accessible file.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}