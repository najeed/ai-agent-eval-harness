{
  "aes_version": 1.4,
  "metadata": {
    "name": "Request an Office Move",
    "compliance_level": "Standard",
    "id": "11091-request-office-move"
  },
  "description": "A faculty member is changing offices and needs to request assistance from facilities to move their belongings.",
  "industry": "Education",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Identify the faculty member, their current office, and their new office location.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent gathers the logistical details.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Create a work order for the facilities team to perform the physical move.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent successfully schedules the move.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Create a related ticket for IT to move and set up the faculty member's computer and phone in the new office.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent successfully schedules the IT portion of the move.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}