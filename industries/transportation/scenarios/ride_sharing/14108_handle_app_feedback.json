{
  "aes_version": 1.2,
  "metadata": {
    "name": "Handle In-App Feedback",
    "compliance_level": "Standard"
  },
  "description": "A rider leaves feedback through the app suggesting a new feature. This feedback needs to be categorized and routed to the product team.",
  "industry": "Transportation",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "The system receives a new piece of feedback from a rider.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "The feedback is logged."
        }
      },
      {
        "id": "task-2",
        "task_description": "An AI tool automatically categorizes the feedback as a 'Feature Request'.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "The feedback is correctly tagged."
        }
      },
      {
        "id": "task-3",
        "task_description": "The system creates a ticket for the feedback.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "A new ticket is created."
        }
      },
      {
        "id": "task-4",
        "task_description": "The ticket is automatically assigned to the 'Product Feedback' queue for the product team to review.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "The feedback is routed to the correct team."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      },
      {
        "from": "task-3",
        "to": "task-4"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}