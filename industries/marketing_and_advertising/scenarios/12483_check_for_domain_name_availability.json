{
  "aes_version": 1.4,
  "metadata": {
    "name": "Check for Domain Name Availability",
    "compliance_level": "Standard",
    "id": "12483-check-for-domain-name-availability"
  },
  "description": "For a new product launch, a brand manager needs to see if a desired domain name is available.",
  "industry": "Marketing and Advertising",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Identify the desired domain name.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent has the name to be checked (e.g., 'newproduct.com').",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Use a domain registrar's WHOIS lookup tool to check the availability of the domain.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent finds that the domain is already registered.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Brainstorm alternative domain names or TLDs (e.g., '.io', '.co') and check their availability.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent finds an available alternative, 'newproduct.io'.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}