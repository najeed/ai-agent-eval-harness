{
  "aes_version": 1.4,
  "metadata": {
    "name": "Optimize Ad for Mobile",
    "compliance_level": "Standard",
    "id": "12477-optimize-ad-for-mobile"
  },
  "description": "A campaign's performance is poor on mobile devices. A manager needs to create a mobile-specific version of an ad.",
  "industry": "Marketing and Advertising",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Duplicate an existing ad.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent creates a copy of the ad to be modified.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "In the new ad, replace the landscape image with a vertical (9:16) image that is better suited for mobile screens.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent uploads a mobile-friendly creative.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Shorten the ad copy to be more concise and easier to read on a small screen.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent edits the copy for mobile-first consumption.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}