{
  "aes_version": 1.2,
  "metadata": {
    "name": "Cancel a Restaurant Reservation",
    "compliance_level": "Standard"
  },
  "description": "A guest calls to cancel their dinner reservation for tonight.",
  "industry": "Hospitality",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Find the reservation in the system using the guest's name.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "The agent locates the booking."
        }
      },
      {
        "id": "task-2",
        "task_description": "Cancel the reservation in the system, freeing up the table.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "The reservation is successfully canceled."
        }
      },
      {
        "id": "task-3",
        "task_description": "Thank the guest and ask if they'd like to book for another time.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "The agent provides good service and attempts to retain the business."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}