{
  "aes_version": 1.2,
  "metadata": {
    "name": "Modify Restaurant Reservation",
    "compliance_level": "Standard"
  },
  "description": "A guest calls to change the time of their existing dinner reservation.",
  "industry": "Hospitality",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Find the guest's existing reservation in the system.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent locates the booking."
        }
      },
      {
        "id": "task-2",
        "task_description": "Check for availability at the new requested time.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent confirms there is a table available at the new time."
        }
      },
      {
        "id": "task-3",
        "task_description": "Update the reservation with the new time and confirm with the guest.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "The booking is successfully modified."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}