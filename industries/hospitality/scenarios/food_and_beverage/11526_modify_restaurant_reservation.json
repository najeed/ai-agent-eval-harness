{
  "aes_version": 1.4,
  "metadata": {
    "name": "Modify Restaurant Reservation",
    "compliance_level": "Standard",
    "id": "11526-modify-restaurant-reservation"
  },
  "description": "A guest calls to change the time of their existing dinner reservation.",
  "industry": "Hospitality",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Find the guest's existing reservation in the system.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent locates the booking.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Check for availability at the new requested time.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent confirms there is a table available at the new time.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Update the reservation with the new time and confirm with the guest.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "The booking is successfully modified.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}