{
  "aes_version": 1.2,
  "metadata": {
    "name": "Process a Vendor Invoice",
    "compliance_level": "Standard"
  },
  "description": "The accounting department receives an invoice from the hotel's linen supply vendor.",
  "industry": "Hospitality",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Enter the invoice details into the accounting system.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Invoice data is accurately entered."
        }
      },
      {
        "id": "task-2",
        "task_description": "Match the invoice against the purchase order and the delivery confirmation.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "A successful 3-way match is confirmed."
        }
      },
      {
        "id": "task-3",
        "task_description": "Approve the invoice for payment and schedule it according to the payment terms.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "The invoice is scheduled for payment in 30 days."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}