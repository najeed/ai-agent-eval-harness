{
  "aes_version": 1.2,
  "metadata": {
    "name": "Correct a Folio Posting Error",
    "compliance_level": "Standard"
  },
  "description": "A front desk agent accidentally posts a restaurant charge to the wrong room.",
  "industry": "Hospitality",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "The agent identifies the error after the guest from the wrong room calls to dispute the charge.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "The error is identified."
        }
      },
      {
        "id": "task-2",
        "task_description": "The agent reverses the incorrect charge from the first guest's folio.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "The incorrect charge is removed."
        }
      },
      {
        "id": "task-3",
        "task_description": "The agent posts the charge to the correct guest's folio and adds a note explaining the correction.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "The charge is moved to the correct room, and the action is documented."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}