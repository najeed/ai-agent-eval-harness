{
  "aes_version": 1.2,
  "metadata": {
    "name": "Modify an Existing Reservation",
    "compliance_level": "Standard"
  },
  "description": "A guest calls to change the dates of their upcoming stay.",
  "industry": "Hospitality",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Retrieve the guest's existing reservation.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent locates the booking."
        }
      },
      {
        "id": "task-2",
        "task_description": "Check availability for the new dates requested by the guest.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent confirms availability for the new dates."
        }
      },
      {
        "id": "task-3",
        "task_description": "Update the reservation with the new dates and inform the guest of any change in rate.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent successfully modifies the booking and clearly communicates the new rate."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}