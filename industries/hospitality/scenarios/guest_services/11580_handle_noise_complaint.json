{
  "aes_version": 1.4,
  "metadata": {
    "name": "Handle a Guest Noise Complaint",
    "compliance_level": "Standard",
    "id": "11580-handle-noise-complaint"
  },
  "description": "A guest calls the front desk late at night to complain about a noisy party in the room next door.",
  "industry": "Hospitality",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Apologize to the complaining guest and assure them the issue will be handled.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "The agent de-escalates the situation.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Dispatch a security officer to the noisy room to issue a warning.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Security is sent to address the complaint.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Log the complaint in the system, tied to both guest rooms.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "The incident is documented.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-4",
        "task_description": "Follow up with the complaining guest 15 minutes later to ensure the noise has subsided.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "The agent follows up to confirm resolution.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      },
      {
        "from": "task-3",
        "to": "task-4"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}