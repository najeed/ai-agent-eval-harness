{
  "aes_version": 1.4,
  "metadata": {
    "name": "Report Open Electrical Pedestal",
    "compliance_level": "Standard",
    "id": "14171-report-open-pedestal"
  },
  "description": "A resident reports that a green electrical box (pedestal) in their front yard is open, with wires exposed.",
  "industry": "Utilities",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Advise the caller to keep a safe distance and not to touch the pedestal.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent provides critical safety instructions.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Get the exact location of the open pedestal.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent accurately records the location.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Create a high-priority service order for a crew to immediately go and secure the pedestal.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent dispatches a crew to address the public safety hazard.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}