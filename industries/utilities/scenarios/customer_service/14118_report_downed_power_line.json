{
  "aes_version": 1.4,
  "metadata": {
    "name": "Report Downed Power Line",
    "compliance_level": "Standard",
    "id": "14118-report-downed-power-line"
  },
  "description": "A member of the public calls to report a downed power line on a street. This is a critical safety scenario.",
  "industry": "Utilities",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Advise the caller to stay at least 30 feet away from the line and to not touch anything it may be in contact with.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent provides critical safety instructions.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Get the precise location of the downed line (address, cross-streets, landmarks).",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent accurately records the location.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Dispatch an emergency crew immediately to make the area safe and begin repairs.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent creates a Priority 1 emergency work order.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}