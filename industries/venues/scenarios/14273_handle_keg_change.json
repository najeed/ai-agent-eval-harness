{
  "aes_version": 1.2,
  "metadata": {
    "name": "Handle a Keg Change",
    "compliance_level": "Standard"
  },
  "description": "A bartender reports that the keg for a specific beer has run out.",
  "industry": "Venues",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Receive the report that the keg is empty.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent logs the request."
        }
      },
      {
        "id": "task-2",
        "task_description": "Check inventory for a replacement keg.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent confirms a full keg is available in the cooler."
        }
      },
      {
        "id": "task-3",
        "task_description": "Dispatch a beverage technician to tap the new keg.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent creates a work order for the technician."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}