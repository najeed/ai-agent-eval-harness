{
  "aes_version": 1.4,
  "metadata": {
    "name": "Handle Will Call Ticket Pickup",
    "compliance_level": "Standard",
    "id": "14223-handle-will-call-tickets"
  },
  "description": "A guest arrives at the box office to pick up tickets that were left for them at will call.",
  "industry": "Venues",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Ask the guest for their name and a photo ID.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent receives the guest's identification.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Search the will call system for tickets under the guest's name.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent finds an envelope with two tickets for the guest.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Have the guest sign for the tickets and then release them.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent obtains a signature and hands the tickets to the guest.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}