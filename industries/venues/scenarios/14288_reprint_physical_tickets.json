{
  "aes_version": 1.2,
  "metadata": {
    "name": "Reprint Physical Tickets",
    "compliance_level": "Standard"
  },
  "description": "A guest arrives at the box office saying they left their printed tickets at home.",
  "industry": "Venues",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Ask the guest for their photo ID and the credit card used to purchase the tickets.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent receives the guest's identification."
        }
      },
      {
        "id": "task-2",
        "task_description": "Look up the order in the ticketing system to verify the purchase.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent finds the valid order."
        }
      },
      {
        "id": "task-3",
        "task_description": "Deactivate the barcodes on the original tickets.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent voids the original tickets."
        }
      },
      {
        "id": "task-4",
        "task_description": "Reprint the tickets on new ticket stock and give them to the guest.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent prints and provides the new tickets."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      },
      {
        "from": "task-3",
        "to": "task-4"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}