{
  "aes_version": 1.2,
  "metadata": {
    "name": "Process Season Ticket Renewal Payment",
    "compliance_level": "Standard"
  },
  "description": "A season ticket holder calls to make a payment for their renewal invoice.",
  "industry": "Venues",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Look up the customer's account and their renewal invoice.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent finds the open invoice."
        }
      },
      {
        "id": "task-2",
        "task_description": "Confirm the amount due with the customer.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent states the correct amount."
        }
      },
      {
        "id": "task-3",
        "task_description": "Process the payment via credit card.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent successfully takes the payment."
        }
      },
      {
        "id": "task-4",
        "task_description": "Mark the invoice as 'Paid' and send a receipt to the customer.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent closes the invoice and sends a confirmation."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      },
      {
        "from": "task-3",
        "to": "task-4"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}