{
  "aes_version": 1.4,
  "metadata": {
    "name": "Handle POS System Failure",
    "compliance_level": "Standard",
    "id": "14220-handle-pos-system-failure"
  },
  "description": "The Point-of-Sale (POS) terminal at a busy concession stand has frozen during an event.",
  "industry": "Venues",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Receive a report of the POS failure from the stand manager.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent logs the issue for the specific terminal.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Attempt to remotely reboot the POS terminal.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "The remote reboot command fails.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Dispatch an IT technician to the concession stand with a replacement terminal.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent dispatches a technician to the location.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}