{
  "aes_version": 1.4,
  "metadata": {
    "name": "Handle a Medical Emergency",
    "compliance_level": "Standard",
    "id": "14237-handle-medical-emergency"
  },
  "description": "A staff member reports that a guest has collapsed and requires medical attention.",
  "industry": "Venues",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Get the exact location of the patient.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent confirms the location.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Dispatch the in-house EMT/paramedic team to the location.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent sends an urgent dispatch to the medical team.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Dispatch a security team to clear a path for the medical team and create a privacy perimeter.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent dispatches security to assist.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-4",
        "task_description": "If directed by the medical team, call 911 for an ambulance.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent contacts external emergency services and provides a clear access point for them.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      },
      {
        "from": "task-3",
        "to": "task-4"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}