{
  "aes_version": 1.2,
  "metadata": {
    "name": "Moderate a Product Review",
    "compliance_level": "Standard"
  },
  "description": "A new product review has been submitted and is waiting for moderation before it appears on the website.",
  "industry": "Retail",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Open the review moderation queue.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "An agent sees the list of pending reviews."
        }
      },
      {
        "id": "task-2",
        "task_description": "Read the review to ensure it does not contain inappropriate language or personal information.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "The agent confirms the review complies with site policies."
        }
      },
      {
        "id": "task-3",
        "task_description": "Approve the review.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "The review is now visible on the product's page on the website."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}