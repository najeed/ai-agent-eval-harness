{
  "aes_version": 1.2,
  "metadata": {
    "name": "Clock In for a Shift",
    "compliance_level": "Standard"
  },
  "description": "A store associate arrives for their shift and needs to clock in.",
  "industry": "Retail",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Access the time clock application on a POS terminal or dedicated device.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "The associate opens the timekeeping software."
        }
      },
      {
        "id": "task-2",
        "task_description": "Enter their employee ID and password.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "The system authenticates the associate."
        }
      },
      {
        "id": "task-3",
        "task_description": "Select the 'Clock In' option.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "The associate's shift start time is successfully recorded."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}