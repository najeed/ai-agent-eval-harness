{
  "aes_version": 1.4,
  "metadata": {
    "name": "Customer Cancels an Order",
    "compliance_level": "Standard",
    "id": "14362-cancel-order"
  },
  "description": "A customer calls to cancel an order they placed earlier in the day.",
  "industry": "Wholesale",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Identify the order the customer wishes to cancel.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent finds the correct order.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Check the order's status to ensure it has not yet been shipped.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent confirms the order has not shipped.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Cancel the order in the system.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent successfully cancels the sales order.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-4",
        "task_description": "Send a cancellation confirmation to the customer.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "The customer receives an email confirming the cancellation.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      },
      {
        "from": "task-3",
        "to": "task-4"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}