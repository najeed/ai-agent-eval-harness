{
  "aes_version": 1.4,
  "metadata": {
    "name": "Customer Changes Order Before Shipping",
    "compliance_level": "Standard",
    "id": "14354-change-order-before-shipping"
  },
  "description": "A customer calls to add an item to an order they just placed, before it has been shipped.",
  "industry": "Wholesale",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Identify the customer's recent order.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent finds the order.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Check the order's status to confirm it has not yet been picked or packed.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent confirms the order is still in the 'confirmed' status and has not been sent to the warehouse.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Add the new item to the sales order.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent successfully modifies the order to include the new item.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-4",
        "task_description": "Send an updated order confirmation to the customer with the new total.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent sends the revised confirmation.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      },
      {
        "from": "task-3",
        "to": "task-4"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}