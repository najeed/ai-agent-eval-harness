{
  "aes_version": 1.4,
  "metadata": {
    "name": "Handle Return of a Defective Product",
    "compliance_level": "Standard",
    "id": "14343-handle-return-of-defective-product"
  },
  "description": "A retailer returns a product that they claim is defective.",
  "industry": "Wholesale",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Receive the returned item and the RMA number.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "The warehouse receives the item.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Inspect the item to verify the defect.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "A technician confirms the product has a manufacturing defect.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Issue a full credit to the retailer.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent credits the retailer's account.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-4",
        "task_description": "Quarantine the defective item and notify the supplier of the quality issue.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "The item is set aside, and a quality report is sent to the original supplier.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      },
      {
        "from": "task-3",
        "to": "task-4"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}