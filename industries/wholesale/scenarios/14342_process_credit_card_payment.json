{
  "aes_version": 1.4,
  "metadata": {
    "name": "Process a Credit Card Payment for an Invoice",
    "compliance_level": "Standard",
    "id": "14342-process-credit-card-payment"
  },
  "description": "A customer calls to pay an outstanding invoice with a credit card.",
  "industry": "Wholesale",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Identify the customer and the specific invoice they wish to pay.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent retrieves the correct invoice.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Securely take the customer's credit card details.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent uses a secure payment portal to enter the card information.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Process the payment through the payment gateway.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "The payment is approved.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-4",
        "task_description": "Mark the invoice as 'paid' and send a receipt to the customer.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "The invoice is closed, and the customer receives a receipt.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      },
      {
        "from": "task-3",
        "to": "task-4"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
