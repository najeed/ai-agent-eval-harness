{
  "aes_version": 1.4,
  "metadata": {
    "name": "Quarantine Damaged Stock",
    "compliance_level": "Standard",
    "id": "14355-quarantine-damaged-stock"
  },
  "description": "A warehouse worker damages a pallet of goods with a forklift. The damaged items must be quarantined and removed from sellable inventory.",
  "industry": "Wholesale",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "The worker reports the incident and the damaged items.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "An incident report is created.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Move the damaged items to a designated quarantine area in the warehouse.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "The items are physically moved.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Adjust the inventory record, moving the damaged quantity from 'sellable' to 'quarantined/damaged' status.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent successfully updates the inventory status for the items.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
