{
  "aes_version": 1.4,
  "metadata": {
    "name": "Handle a Short Shipment Claim",
    "compliance_level": "Standard",
    "id": "14329-handle-short-shipment-claim"
  },
  "description": "A retailer claims they were short-shipped on a recent order (i.e., they received fewer items than they were billed for).",
  "industry": "Wholesale",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Receive the short shipment claim from the retailer.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent logs the claim.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Review the original pick list and the packing video for the order.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent reviews the evidence and confirms that the item was indeed short-packed.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Issue a credit to the retailer for the missing item.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent credits the retailer's account.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-4",
        "task_description": "Provide feedback to the warehouse team to prevent future errors.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent sends a report to the warehouse manager about the picking error.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      },
      {
        "from": "task-3",
        "to": "task-4"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}