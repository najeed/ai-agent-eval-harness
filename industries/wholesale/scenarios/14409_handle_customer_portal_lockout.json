{
  "aes_version": 1.2,
  "metadata": {
    "name": "Handle Customer Portal Account Lockout",
    "compliance_level": "Standard"
  },
  "description": "A retailer's employee has been locked out of the online ordering portal after too many failed login attempts.",
  "industry": "Wholesale",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Receive a call from the user who is locked out.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent identifies the user's account."
        }
      },
      {
        "id": "task-2",
        "task_description": "Verify the user's identity.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent confirms the user is who they say they are."
        }
      },
      {
        "id": "task-3",
        "task_description": "Unlock the user's account and trigger a password reset.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent unlocks the account and sends a password reset link to the user's email."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}