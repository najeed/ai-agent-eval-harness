{
  "aes_version": 1.4,
  "metadata": {
    "name": "Handle a Purchase Order Cancellation",
    "compliance_level": "Standard",
    "id": "14392-handle-po-cancellation"
  },
  "description": "A procurement manager needs to cancel a purchase order that was placed with a supplier but is no longer needed.",
  "industry": "Wholesale",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Identify the purchase order to be cancelled.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent finds the correct PO.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Check the PO status to ensure the supplier has not already shipped it.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent confirms the order is not yet shipped.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Contact the supplier to formally cancel the purchase order.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent sends a cancellation request to the supplier.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-4",
        "task_description": "Update the status of the PO in the system to 'Cancelled'.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent successfully cancels the PO.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      },
      {
        "from": "task-3",
        "to": "task-4"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}