{
  "aes_version": 1.2,
  "metadata": {
    "name": "Handle an Inventory Recount Request",
    "compliance_level": "Standard"
  },
  "description": "After a cycle count reveals a discrepancy, a manager requests a blind recount of the specific item to verify.",
  "industry": "Wholesale",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Identify the item that needs a recount.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent knows which item to recount."
        }
      },
      {
        "id": "task-2",
        "task_description": "Assign a different warehouse worker to perform a blind recount (without seeing the system quantity).",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "A new count is initiated."
        }
      },
      {
        "id": "task-3",
        "task_description": "The second count matches the first physical count, confirming the system quantity is wrong.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "The discrepancy is confirmed."
        }
      },
      {
        "id": "task-4",
        "task_description": "Adjust the inventory record based on the confirmed physical count.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "The system inventory is corrected."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      },
      {
        "from": "task-3",
        "to": "task-4"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}