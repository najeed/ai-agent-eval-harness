{
  "aes_version": 1.4,
  "metadata": {
    "name": "Clip Highlights for Social Media",
    "compliance_level": "Standard",
    "id": "13647-clip-highlights-for-social-media"
  },
  "description": "Immediately after a game, a social media manager needs to create and post highlight clips.",
  "industry": "Sports",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Access the full recording of the game broadcast.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent has the full video file.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-2",
        "task_description": "Use an AI tool to automatically identify the most exciting plays (e.g., goals, big hits).",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "The tool generates a list of timestamps for potential highlights.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-3",
        "task_description": "Create short video clips for the top 3 highlights.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent generates three highlight clips.",
            "mode": "regex"
          }
        ]
      },
      {
        "id": "task-4",
        "task_description": "Post the clips to the team's social media accounts.",
        "expected_outcome": [
          {
            "target": "message",
            "expected": "Agent successfully posts the highlights.",
            "mode": "regex"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      },
      {
        "from": "task-3",
        "to": "task-4"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}