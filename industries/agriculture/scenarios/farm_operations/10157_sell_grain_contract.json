{
  "aes_version": 1.2,
  "metadata": {
    "name": "Execute a Grain Sales Contract",
    "compliance_level": "Standard"
  },
  "description": "A farmer has decided to sell 5,000 bushels of corn to a local ethanol plant.",
  "industry": "Agriculture",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Get the current cash price for corn from the specified ethanol plant.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent retrieves the current price."
        }
      },
      {
        "id": "task-2",
        "task_description": "Generate a grain sales contract for 5,000 bushels at the current price for a specific delivery period.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent creates a formal sales contract."
        }
      },
      {
        "id": "task-3",
        "task_description": "Send the contract to the farmer for digital signature.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent successfully sends the contract."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
