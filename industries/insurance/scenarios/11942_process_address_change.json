          "value": "Agent accurately captures the new address."
        }
      },
      {
        "id": "task-3",
        "task_description": "Update the address in the policy administration system.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent successfully updates the address and confirms the change."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
