{
  "aes_version": 1.2,
  "metadata": {
    "name": "Add an Additional Insured",
    "compliance_level": "Standard"
  },
  "description": "A small business needs to add a client as an additional insured on their general liability policy for a specific project.",
  "industry": "Insurance",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Identify the business policyholder.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent locates the correct policy."
        }
      },
      {
        "id": "task-2",
        "task_description": "Collect the name and address of the entity to be added as an additional insured.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent accurately captures the information."
        }
      },
      {
        "id": "task-3",
        "task_description": "Add the additional insured endorsement to the policy.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent successfully adds the endorsement and generates an updated Certificate of Insurance."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}