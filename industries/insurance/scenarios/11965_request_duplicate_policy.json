{
  "aes_version": 1.2,
  "metadata": {
    "name": "Request a Duplicate Policy Document",
    "compliance_level": "Standard"
  },
  "description": "A policyholder has misplaced their physical life insurance policy and wants a new copy.",
  "industry": "Insurance",
  "workflow": {
    "nodes": [
      {
        "id": "task-1",
        "task_description": "Identify and authenticate the policyholder.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent securely verifies the customer."
        }
      },
      {
        "id": "task-2",
        "task_description": "Process the request for a duplicate policy document.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent successfully generates a copy of the policy contract."
        }
      },
      {
        "id": "task-3",
        "task_description": "Mail the new document to the policyholder's address of record.",
        "expected_outcome": {
          "type": "typed_value",
          "data_type": "object",
          "value": "Agent initiates the mailing of the physical document."
        }
      }
    ],
    "edges": [
      {
        "from": "task-1",
        "to": "task-2"
      },
      {
        "from": "task-2",
        "to": "task-3"
      }
    ]
  },
  "evaluation": {
    "consensus": {
      "strategy": "Majority_Vote",
      "min_judges": 1,
      "judge_panel": [
        "Luna-1"
      ]
    }
  }
}