{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Eval Specification (AES) - Unified Evolution Standard",
  "type": "object",
  "required": ["aes_version", "metadata", "workflow"],
  "properties": {
    "aes_version": {
      "type": "number",
      "const": 1.2
    },
    "metadata": {
      "type": "object",
      "required": ["name", "compliance_level"],
      "properties": {
        "name": { "type": "string" },
        "compliance_level": {
          "type": "string",
          "enum": ["Standard", "Gold", "Regulatory_Audit"]
        },
        "standards_registry": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["ISO_20022", "HL7_FHIR_V4", "SWIFT_MT103", "PCI_DSS_v4", "HIPAA_REG_A"]
          }
        }
      }
    },
    "workflow": {
      "type": "object",
      "description": "The State-Machine DAG defining agentic transitions.",
      "required": ["nodes", "edges"],
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "task_description"],
            "properties": {
              "id": { "type": "string" },
              "task_description": { "type": "string" },
              "state_hygiene": {
                "type": "object",
                "description": "Assertions to check BEFORE this node can execute."
              },
              "expected_outcome": {
                "oneOf": [
                  {
                    "type": "object",
                    "properties": {
                      "type": { "const": "standard_ref" },
                      "schema_id": { "type": "string" },
                      "value": { "type": "object" }
                    }
                  },
                  {
                    "type": "object",
                    "properties": {
                      "type": { "const": "typed_value" },
                      "data_type": { "enum": ["string", "number", "boolean", "object", "array"] },
                      "value": {}
                    }
                  }
                ]
              }
            }
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to"],
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "condition": { "type": "string", "description": "Logical condition to trigger the transition." }
            }
          }
        }
      }
    },
    "evaluation": {
      "type": "object",
      "properties": {
        "consensus": {
          "type": "object",
          "required": ["strategy", "min_judges"],
          "properties": {
            "strategy": { "enum": ["Majority_Vote", "Weighted_Average", "Absolute_Unanimity"] },
            "min_judges": { "type": "integer", "minimum": 1 },
            "judge_panel": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "ija_threshold": { 
          "type": "number", 
          "minimum": 0, 
          "maximum": 1, 
          "description": "Inter-Judge Agreement threshold (0.0 to 1.0)."
        }
      }
    }
  }
}
