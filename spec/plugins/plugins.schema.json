{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Plugin Forensic Registry Schema",
  "description": "Schema for the AgentV registry.json configuration file",
  "type": "object",
  "required": [
    "plugins"
  ],
  "properties": {
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "module",
          "class"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique forensic identifier for the plugin (usually lowercase class name)"
          },
          "name": {
            "type": "string",
            "description": "Human-readable name of the plugin"
          },
          "module": {
            "type": "string",
            "description": "Python module name or stem (e.g., flight_recorder)"
          },
          "class": {
            "type": "string",
            "description": "Authoritative class name within the module (e.g., FlightRecorderPlugin)"
          },
          "config": {
            "type": "object",
            "description": "Optional plugin-specific configuration"
          },
          "enabled": {
            "type": "boolean",
            "default": true
          }
        }
      }
    }
  }
}
