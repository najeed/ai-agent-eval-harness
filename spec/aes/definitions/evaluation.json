{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AES Evaluation Definition",
  "type": "object",
  "properties": {
    "consensus": {
      "type": "object",
      "required": ["strategy", "min_judges"],
      "properties": {
        "strategy": {
          "enum": ["Majority_Vote", "Weighted_Average", "Absolute_Unanimity"]
        },
        "min_judges": {
          "type": "integer",
          "minimum": 1
        },
        "judge_panel": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "ija_threshold": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Inter-Judge Agreement threshold (0.0 to 1.0)."
    }
  }
}
