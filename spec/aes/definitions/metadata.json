{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AES Metadata Definition",
  "type": "object",
  "required": ["name", "compliance_level"],
  "properties": {
    "name": { "type": "string" },
    "id": { "type": "string" },
    "compliance_level": {
      "type": "string",
      "enum": ["Standard", "Gold", "Regulatory_Audit"]
    },
    "standards_registry": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "ISO_20022", "SWIFT_MT103", "PCI_DSS_V4", "PSD2", "BASEL_III", "MIFID_II", "SOX", "GLBA",
          "HL7_FHIR_V4", "ICD_10", "ICD_11", "DICOM", "HIPAA", "HITECH",
          "ISO_27001", "SOC_2", "CIS_BENCHMARKS", "NIST_CSF", "FISMA", "FIPS_140_3", "ISO_19790",
          "GDPR", "CCPA", "LGPD", "PIPEDA", "FEDRAMP", "ISO_27701",
          "X_509", "SAML_V2", "OAUTH_2", "OIDC",
          "IEC_61850", "IEEE_1547", "IEC_62351", "NERC_CIP",
          "ISA_95", "OPC_UA", "IEC_62443", "ISO_50001", "ISO_45001",
          "ISO_42001", "ISO_23894", "EU_AI_ACT", "NIST_AI_RMF", "OECD_AI_PRINCIPLES", "UNESCO_AI_ETHICS",
          "3GPP_5G", "ISO_9594", "IETF_RFC",
          "ISO_11179", "W3C_XML", "W3C_RDF", "W3C_OWL", "DUBLIN_CORE", "DCAT",
          "ISO_9001", "ISO_14001", "ISO_31000", "COSO_ERM", "COBIT", "ESG_GRI", "ESG_SASB", "ESG_ISSB"
        ]
      }
    },
    "agent_topology": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "writes": { "type": "array", "items": { "type": "string" } },
          "reads": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "policies": {
       "type": "object",
       "additionalProperties": { "type": "object" }
    }
  }
}
